# Copy to .env and edit. .env is gitignored.

# --- Ingest server ---
INGEST_PORT=8001
# Set to 1 to run the FastAPI uploader without booting the inference runner.
# Useful for local dev on a Mac (no CUDA).
INGEST_DISABLE_INFERENCE=0

# --- Viser streaming viewer ---
INGEST_VISER_ENABLED=1
INGEST_VISER_PORT=8890

# --- LingBot-Map runtime ---
# streaming = real-time mode; windowed = better for >3000 frame sessions.
LINGBOT_MODE=streaming
LINGBOT_FPS=10
LINGBOT_WINDOW_SIZE=64

# Toggle outdoor sky masking (requires onnxruntime, installed in the image).
MASK_SKY=0
# Force PyTorch SDPA fallback if FlashInfer didn't build for this arch.
USE_SDPA=0

# --- Session lifecycle ---
# Recording sessions auto-close after this many seconds with no new frames.
SESSION_IDLE_SECONDS=30

# --- Hugging Face ---
# Only needed if the model repo becomes gated. setup.sh reads this.
# HF_TOKEN=hf_xxx

# --- Optional: override which lingbot-map ref scripts/setup.sh checks out.
LINGBOT_REPO=https://github.com/robbyant/lingbot-map.git
LINGBOT_REF=main
