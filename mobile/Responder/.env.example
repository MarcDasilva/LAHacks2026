# Responder Zetic inference environment template
# Copy this file to `.env` and fill in your local values.

ZETIC_PERSONAL_KEY=your_zetic_personal_key_here
ZETIC_TOKEN=your_zetic_token_here
ZETIC_AUDIO_ENCODER_MODEL_NAME=zetic/qwen2.5_omni_audio_encoder_chunk_f16
ZETIC_DECODER_MODEL_NAME=zetic/QWEN_2.5_omni_3b_decoder
ZETIC_MODEL_VERSION=1
ZETIC_MODEL_MODE=RUN_AUTO
RESPONDER_AUDIO_USER_PROMPT=Transcribe this audio in English.
RESPONDER_AUDIO_SYSTEM_PROMPT=You are a precise audio transcription assistant.
RESPONDER_MAX_RESPONSE_TOKENS=256
RESPONDER_CHUNK_FRAMES=45
RESPONDER_AUDIO_SAMPLES_PER_CHUNK=32000
RESPONDER_SESSION_ID=optional-session-id
RESPONDER_STT_ON_HOLD=true
RESPONDER_FRAME_STREAM_ENABLED=true
RESPONDER_FRAME_STREAM_WS_URL=ws://192.168.1.10:8787
RESPONDER_FRAME_STREAM_ROOM_ID=main-camera
RESPONDER_FRAME_STREAM_FPS=10
RESPONDER_FRAME_STREAM_JPEG_QUALITY=0.65
